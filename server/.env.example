# Server Configuration
MONGO_URI=mongodb://localhost:27017/sarthi
JWT_SECRET=your_jwt_secret_here
PORT=5000

# Email OTP (Nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Internship APIs (Adzuna & RapidAPI)
ADZUNA_API_ID=your_adzuna_id
ADZUNA_API_KEY=your_adzuna_key
RAPIDAPI_KEY=your_rapidapi_key
INTERNSHIPS_API_HOST=internships-api.p.rapidapi.com

# Chatbot APIs (OpenAI, Gemini, OpenRouter)
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=your_openrouter_key

# External Services
APIFY_API_TOKEN=your_apify_token

# CORS
CLIENT_URL=http://localhost:5173
